<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox alignment="TOP_CENTER" spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pizzolo.com.controller.GameController">

    <!-- INTESTAZIONE -->
    <VBox style="-fx-padding: 15; -fx-background-color: #1565C0; -fx-border-radius: 5;" spacing="5">
        <Label text="⚓ BATTAGLIA NAVALE" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
        <Label text="Posiziona le tue navi sulla griglia a sinistra" style="-fx-text-fill: #BBDEFB; -fx-font-size: 12;"/>
    </VBox>

    <!-- SEZIONE NAVI DISPONIBILI -->
    <VBox style="-fx-border-color: #1565C0; -fx-border-width: 2; -fx-padding: 15; -fx-background-color: #E3F2FD; -fx-border-radius: 5;" spacing="10">
        <Label text="🚢 NAVI DISPONIBILI - Trascina sulla griglia personale" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>

        <Separator/>

        <HBox fx:id="hBoxFlottaDisponibile" spacing="20" style="-fx-padding: 10; -fx-alignment: CENTER_LEFT;">
        </HBox>
    </VBox>

    <!-- GRIGLIE DI GIOCO -->
    <HBox alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS">

        <!-- SINISTRA: La tua flotta -->
        <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="0" HBox.hgrow="ALWAYS" style="-fx-border-color: #4CAF50; -fx-border-width: 2; -fx-border-radius: 5;">

            <HBox alignment="CENTER" maxWidth="Infinity" style="-fx-background-color: #4CAF50; -fx-padding: 12; -fx-border-radius: 5 5 0 0;">
                <Label text="🛡️ LA TUA FLOTTA" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            </HBox>

            <VBox fx:id="vBoxFlottaPersonale" maxHeight="Infinity" maxWidth="Infinity" VBox.vgrow="ALWAYS" style="-fx-padding: 5;">
                <GridPane fx:id="gridPanePersonale" alignment="CENTER" gridLinesVisible="true" hgap="1"
                          maxHeight="Infinity" maxWidth="Infinity" vgap="1" VBox.vgrow="ALWAYS"
                          style="-fx-padding: 5; -fx-border-color: #E0E0E0;">
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" percentWidth="4"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints percentHeight="4" vgrow="NEVER"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                    </rowConstraints>

                    <!-- Numeri colonne -->
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="1" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="2" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="3" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="4" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="5" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="6" GridPane.columnIndex="6" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="7" GridPane.columnIndex="7" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="8" GridPane.columnIndex="8" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="9" GridPane.columnIndex="9" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="10" GridPane.columnIndex="10" GridPane.rowIndex="0"/>

                    <!-- Lettere righe -->
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="A" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="B" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="C" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="D" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="E" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="F" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="G" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="H" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="I" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" text="J" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
                </GridPane>
            </VBox>
        </VBox>

        <!-- DESTRA: La flotta nemica -->
        <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="0" HBox.hgrow="ALWAYS" style="-fx-border-color: #FF6B6B; -fx-border-width: 2; -fx-border-radius: 5;">

            <HBox alignment="CENTER" maxWidth="Infinity" style="-fx-background-color: #FF6B6B; -fx-padding: 12; -fx-border-radius: 5 5 0 0;">
                <Label text="⚔️ FLOTTA NEMICA" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            </HBox>

            <VBox fx:id="vBoxFlottaNemica" maxHeight="Infinity" maxWidth="Infinity" VBox.vgrow="ALWAYS" style="-fx-padding: 5;">
                <GridPane fx:id="gridPaneNemica" alignment="CENTER" gridLinesVisible="true" hgap="1"
                          maxHeight="Infinity" maxWidth="Infinity" vgap="1" VBox.vgrow="ALWAYS"
                          style="-fx-padding: 5; -fx-border-color: #E0E0E0;">
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" percentWidth="4"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="9.6"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints percentHeight="4" vgrow="NEVER"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="9.6" vgrow="ALWAYS"/>
                    </rowConstraints>

                    <!-- Numeri colonne -->
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="1" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="2" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="3" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="4" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="5" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="6" GridPane.columnIndex="6" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="7" GridPane.columnIndex="7" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="8" GridPane.columnIndex="8" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="9" GridPane.columnIndex="9" GridPane.rowIndex="0"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="10" GridPane.columnIndex="10" GridPane.rowIndex="0"/>

                    <!-- Lettere righe -->
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="A" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="B" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="C" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="D" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="E" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="F" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="G" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="H" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="I" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                    <Label alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #FF6B6B;" text="J" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
                </GridPane>
            </VBox>
        </VBox>

    </HBox>

    <!-- BOTTONE E STATUS IN FONDO -->
    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 15; -fx-background-color: #FAFAFA; -fx-border-radius: 5;">
        <Label fx:id="labelStatus"
               text="ℹ️ Posiziona le navi, poi premi 'Inizia partita'. Tasto R = ruota."
               style="-fx-text-fill: #555; -fx-font-style: italic; -fx-font-size: 12;"/>
        <Button fx:id="btnIniziaPartita"
                text="🎮 Inizia partita"
                onAction="#onIniziaPartita"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25 10 25; -fx-font-size: 14;"/>
    </HBox>

</VBox>